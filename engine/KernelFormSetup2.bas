    n = IL(cm, n, "    If lstVersions.ListIndex < 0 Then")
    n = IL(cm, n, "        MsgBox ""Select a version to delete."", vbExclamation, ""RDK""")
    n = IL(cm, n, "        Exit Sub")
    n = IL(cm, n, "    End If")
