' KernelFormSetup2.bas
' Purpose: WorkspaceExplorer form creation + event code.
' Split from KernelFormSetup.bas (AD-09: module size limit).

Public Sub CreateWorkspaceExplorer()
    Dim comp As Object
    Set comp = ThisWorkbook.VBProject.VBComponents.Add(3)
    comp.Name = "WorkspaceExplorer"
    Dim d As Object: Set d = comp.designer
    ' Config-driven title from branding
    Dim wsTitle As String
    wsTitle = KernelConfig.GetBrandingSetting("CompanyName")
    If Len(wsTitle) = 0 Then wsTitle = "RDK"
    comp.Properties("Caption") = wsTitle & " -- Workspaces"
    comp.Properties("Width") = 500
    comp.Properties("Height") = 360

    ' --- Top bar: workspace selector ---
    AddOptionButton d, "optActive", "Active", 12, 8, 60, 18
    AddOptionButton d, "optArchived", "Archived", 76, 8, 70, 18
    AddLabel d, "lblWorkspace", "Workspace:", 160, 10, 58, 18
    AddComboBox d, "cmbWorkspace", 222, 8, 200, 20
    AddButton d, "btnNewWS", "New", 430, 8, 50, 22

    ' --- Workspace metadata ---
    AddLabel d, "lblWSMeta", "", 12, 32, 470, 14
    Dim metaCtrl As Object
    Set metaCtrl = d.Controls("lblWSMeta")
    metaCtrl.Font.Size = 8
    metaCtrl.ForeColor = &H808080

    ' --- Version list (3 columns: Version, Date, Description) ---
    AddLabel d, "lblVersions", "Versions:", 12, 50, 60, 14
    AddListBox d, "lstVersions", 12, 66, 470, 180, 6, "50;130;200;50;90;60"

    ' --- Active indicator ---
    AddLabel d, "lblActive", "", 12, 250, 470, 14
    Dim actCtrl As Object
    Set actCtrl = d.Controls("lblActive")
    actCtrl.Font.Size = 8
    actCtrl.Font.Italic = True
    actCtrl.ForeColor = &HC47244

    ' --- Primary action buttons (y=270) ---
    AddButton d, "btnSave", "Save", 12, 270, 70, 28
    AddButton d, "btnLoadAll", "Load", 88, 270, 70, 28
    AddButton d, "btnPin", "Pin / Unpin", 164, 270, 80, 28
    AddButton d, "btnInspect", "Inspect", 250, 270, 70, 28
    AddButton d, "btnMore", "More...", 326, 270, 70, 28

    ' --- Hidden buttons (called from More popup, not on main form) ---
    ' These are needed for the code handlers but placed off-screen
    AddButton d, "btnBranch", "", -100, -100, 1, 1
    AddButton d, "btnArchive", "", -100, -100, 1, 1
    AddButton d, "btnDelete", "", -100, -100, 1, 1
    AddButton d, "btnRename", "", -100, -100, 1, 1
    AddButton d, "btnDesc", "", -100, -100, 1, 1
    AddButton d, "btnCompare", "", -100, -100, 1, 1
    AddButton d, "btnSortDate", "", -100, -100, 1, 1
    AddButton d, "btnSortName", "", -100, -100, 1, 1

    AddWorkspaceExplorerCode comp.CodeModule
End Sub

