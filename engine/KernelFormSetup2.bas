    n = IL(cm, n, "    Dim vDir As String: vDir = baseDir & ""\"" & verName")
    n = IL(cm, n, "    If fso.FolderExists(vDir) Then fso.DeleteFolder vDir, True")
    n = IL(cm, n, "    Set fso = Nothing")
    n = IL(cm, n, "    On Error GoTo 0")
    n = IL(cm, n, "    LoadVersionList")
    n = IL(cm, n, "    UpdateWSMeta")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnRename_Click()")
    n = IL(cm, n, "    If cmbWorkspace.ListIndex < 0 Then")
    n = IL(cm, n, "        MsgBox ""Select a workspace to rename."", vbExclamation, ""RDK""")
    n = IL(cm, n, "        Exit Sub")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    Dim oldName As String")
    n = IL(cm, n, "    oldName = GetRealWSName()")
    n = IL(cm, n, "    Dim newName As String")
    n = IL(cm, n, "    newName = InputBox(""New name for workspace '"" & oldName & ""':"", ""RDK -- Rename"", oldName)")
    n = IL(cm, n, "    If Len(Trim(newName)) = 0 Or StrComp(Trim(newName), oldName, vbTextCompare) = 0 Then Exit Sub")
    n = IL(cm, n, "    On Error Resume Next")
    n = IL(cm, n, "    Dim fso As Object")
    n = IL(cm, n, "    Set fso = CreateObject(""Scripting.FileSystemObject"")")
    n = IL(cm, n, "    Dim root As String: root = ThisWorkbook.Path & ""\..""")
    n = IL(cm, n, "    Dim baseDir As String")
    n = IL(cm, n, "    If optActive.Value Then")
    n = IL(cm, n, "        baseDir = root & ""\workspaces""")
    n = IL(cm, n, "    Else")
    n = IL(cm, n, "        baseDir = root & ""\workspaces\archive""")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    fso.MoveFolder baseDir & ""\"" & oldName, baseDir & ""\"" & Trim(newName)")
    n = IL(cm, n, "    Set fso = Nothing")
    n = IL(cm, n, "    On Error GoTo 0")
    n = IL(cm, n, "    LoadWorkspaceList")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnDesc_Click()")
    n = IL(cm, n, "    If lstVersions.ListIndex < 0 Then")
    n = IL(cm, n, "        MsgBox ""Select a version."", vbExclamation, ""RDK""")
    n = IL(cm, n, "        Exit Sub")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    Dim curDesc As String")
    n = IL(cm, n, "    curDesc = lstVersions.List(lstVersions.ListIndex, 2)")
    n = IL(cm, n, "    Dim newDesc As String")
    n = IL(cm, n, "    newDesc = InputBox(""Description:"", ""RDK -- Edit Description"", curDesc)")
    n = IL(cm, n, "    If Len(newDesc) = 0 Then Exit Sub")
    n = IL(cm, n, "    Dim wsName As String")
    n = IL(cm, n, "    wsName = GetRealWSName()")
    n = IL(cm, n, "    Dim verName As String")
    n = IL(cm, n, "    verName = lstVersions.List(lstVersions.ListIndex, 0)")
    n = IL(cm, n, "    Dim root As String: root = ThisWorkbook.Path & ""\..""")
    n = IL(cm, n, "    Dim baseDir As String")
    n = IL(cm, n, "    If optActive.Value Then")
    n = IL(cm, n, "        baseDir = root & ""\workspaces\"" & wsName")
    n = IL(cm, n, "    Else")
    n = IL(cm, n, "        baseDir = root & ""\workspaces\archive\"" & wsName")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    Dim mPath As String: mPath = baseDir & ""\"" & verName & ""\manifest.json""")
    n = IL(cm, n, "    If Dir(mPath) <> """" Then")
    n = IL(cm, n, "        On Error Resume Next")
    n = IL(cm, n, "        Dim fn As Integer: fn = FreeFile")
    n = IL(cm, n, "        Dim content As String")
    n = IL(cm, n, "        Open mPath For Binary Access Read As #fn")
    n = IL(cm, n, "        content = Space$(LOF(fn))")
    n = IL(cm, n, "        Get #fn, , content")
    n = IL(cm, n, "        Close #fn")
    n = IL(cm, n, "        Dim Q As String: Q = Chr(34)")
    n = IL(cm, n, "        Dim oldPat As String")
    n = IL(cm, n, "        oldPat = Q & ""description"" & Q & "": "" & Q & curDesc & Q")
    n = IL(cm, n, "        Dim newPat As String")
    n = IL(cm, n, "        newPat = Q & ""description"" & Q & "": "" & Q & newDesc & Q")
    n = IL(cm, n, "        content = Replace(content, oldPat, newPat)")
    n = IL(cm, n, "        fn = FreeFile")
    n = IL(cm, n, "        Open mPath For Output As #fn")
    n = IL(cm, n, "        Print #fn, content")
    n = IL(cm, n, "        Close #fn")
    n = IL(cm, n, "        On Error GoTo 0")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    LoadVersionList")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnCompare_Click()")
    n = IL(cm, n, "    If lstVersions.ListCount < 2 Then")
    n = IL(cm, n, "        MsgBox ""Need at least 2 versions to compare."", vbExclamation, ""RDK""")
    n = IL(cm, n, "        Exit Sub")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    MsgBox ""Select two versions (hold Ctrl) and use Compare from the Snapshot Explorer (dev mode)."" & vbCrLf & _")
    n = IL(cm, n, "           ""Full workspace compare coming soon."", vbInformation, ""RDK""")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnMore_Click()")
    n = IL(cm, n, "    MoreActions.Show vbModal")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnPin_Click()")
    n = IL(cm, n, "    If cmbWorkspace.ListIndex < 0 Then Exit Sub")
    n = IL(cm, n, "    Dim wsN As String: wsN = GetRealWSName()")
    n = IL(cm, n, "    If KernelWorkspace.IsWorkspacePinned(wsN) Then")
    n = IL(cm, n, "        KernelWorkspace.UnpinWorkspace wsN")
    n = IL(cm, n, "    Else")
    n = IL(cm, n, "        KernelWorkspace.PinWorkspace wsN")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    LoadWorkspaceList")
    n = IL(cm, n, "    Dim si As Long")
    n = IL(cm, n, "    For si = 0 To cmbWorkspace.ListCount - 1")
    n = IL(cm, n, "        Dim chk As String: chk = cmbWorkspace.List(si)")
    n = IL(cm, n, "        If Left(chk, 4) = ""[P] "" Then chk = Mid(chk, 5)")
    n = IL(cm, n, "        If StrComp(chk, wsN, vbTextCompare) = 0 Then")
    n = IL(cm, n, "            cmbWorkspace.ListIndex = si")
    n = IL(cm, n, "            Exit For")
    n = IL(cm, n, "        End If")
    n = IL(cm, n, "    Next si")
    n = IL(cm, n, "End Sub")
    n = IL(cm, n, "")
    n = IL(cm, n, "Private Sub btnInspect_Click()")
    n = IL(cm, n, "    If cmbWorkspace.ListIndex < 0 Then Exit Sub")
    n = IL(cm, n, "    Dim wsN As String: wsN = GetRealWSName()")
    n = IL(cm, n, "    Dim inspVer As Long: inspVer = 0")
    n = IL(cm, n, "    If lstVersions.ListIndex >= 0 Then")
    n = IL(cm, n, "        Dim vn As String: vn = lstVersions.List(lstVersions.ListIndex, 0)")
    n = IL(cm, n, "        If Len(vn) > 1 Then inspVer = CLng(Mid(vn, 2))")
    n = IL(cm, n, "    End If")
    n = IL(cm, n, "    MsgBox KernelWorkspace.CheckWorkspaceCompleteness(wsN, inspVer), vbInformation, ""RDK -- "" & wsN")
    n = IL(cm, n, "End Sub")
End Sub


