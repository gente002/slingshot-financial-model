' =============================================================================
' FORM: AssumptionExplorer
' ListBox-based assumption manager with filter, detail panel, CRUD buttons.
' =============================================================================
Public Sub CreateAssumptionExplorer()
    Dim comp As Object
    Set comp = ThisWorkbook.VBProject.VBComponents.Add(3)
    comp.Name = "AssumptionExplorer"
    Dim d As Object: Set d = comp.Designer
    comp.Properties("Caption") = "Assumption Manager"
    comp.Properties("Width") = 620
    comp.Properties("Height") = 420

    ' --- Filter bar ---
    KernelFormSetup.AddOptionButton d, "optAll", "All", 12, 8, 40, 18
    KernelFormSetup.AddOptionButton d, "optHighSens", "High Sensitivity", 56, 8, 100, 18
    KernelFormSetup.AddOptionButton d, "optStale", "Stale (>90 days)", 160, 8, 100, 18
    KernelFormSetup.AddLabel d, "lblCount", "", 280, 10, 120, 14
    Dim cntCtrl As Object
    Set cntCtrl = d.Controls("lblCount")
    cntCtrl.Font.Size = 8
    cntCtrl.ForeColor = &H808080

    ' --- Assumption list (7 columns: ID, Category, Description, Confidence, Sensitivity, Owner, Reviewed) ---
    KernelFormSetup.AddListBox d, "lstAssumptions", 12, 30, 590, 200, 7, "35;70;200;60;60;50;70"

    ' --- Detail panel ---
    KernelFormSetup.AddLabel d, "lblDetail", "", 12, 236, 590, 50
    Dim detCtrl As Object
    Set detCtrl = d.Controls("lblDetail")
    detCtrl.Font.Size = 8
    detCtrl.ForeColor = &H404040
    detCtrl.WordWrap = True

    ' --- Action buttons ---
    KernelFormSetup.AddButton d, "btnAdd", "Add New", 12, 294, 80, 28
    KernelFormSetup.AddButton d, "btnEdit", "Edit", 98, 294, 70, 28
    KernelFormSetup.AddButton d, "btnArchive", "Archive", 174, 294, 70, 28
    KernelFormSetup.AddButton d, "btnReview", "Mark Reviewed", 250, 294, 100, 28
    KernelFormSetup.AddButton d, "btnClear", "Clear All", 356, 294, 70, 28
    KernelFormSetup.AddButton d, "btnRefresh", "Refresh", 530, 294, 70, 28

    AddAssumptionExplorerCode comp.CodeModule
End Sub

Private Sub AddAssumptionExplorerCode(ByVal cm As Object)
    If cm.CountOfLines > 0 Then cm.DeleteLines 1, cm.CountOfLines
    Dim n As Long: n = 1
    n = KernelFormSetup.IL(cm, n, "Option Explicit")
    n = KernelFormSetup.IL(cm, n, "")
    n = KernelFormSetup.IL(cm, n, "Private Sub UserForm_Initialize()")
    n = KernelFormSetup.IL(cm, n, "    optAll.Value = True")
    n = KernelFormSetup.IL(cm, n, "    LoadList")
    n = KernelFormSetup.IL(cm, n, "End Sub")
    n = KernelFormSetup.IL(cm, n, "")
    n = KernelFormSetup.IL(cm, n, "Private Sub optAll_Click(): LoadList: End Sub")
    n = KernelFormSetup.IL(cm, n, "Private Sub optHighSens_Click(): LoadList: End Sub")
    n = KernelFormSetup.IL(cm, n, "Private Sub optStale_Click(): LoadList: End Sub")
    n = KernelFormSetup.IL(cm, n, "")
    n = KernelFormSetup.IL(cm, n, "Private Sub LoadList()")
    n = KernelFormSetup.IL(cm, n, "    lstAssumptions.Clear")
    n = KernelFormSetup.IL(cm, n, "    lblDetail.Caption = """"")
    n = KernelFormSetup.IL(cm, n, "    On Error Resume Next")
    n = KernelFormSetup.IL(cm, n, "    Dim wsC As Worksheet")
    n = KernelFormSetup.IL(cm, n, "    Set wsC = ThisWorkbook.Sheets(""Config"")")
    n = KernelFormSetup.IL(cm, n, "    If wsC Is Nothing Then Exit Sub")
    n = KernelFormSetup.IL(cm, n, "    Dim sr As Long")
    n = KernelFormSetup.IL(cm, n, "    sr = KernelConfigLoader.FindSectionStart(wsC, ""=== ASSUMPTIONS_CONFIG ==="")")
    n = KernelFormSetup.IL(cm, n, "    If sr = 0 Then Exit Sub")
    n = KernelFormSetup.IL(cm, n, "    Dim dr As Long: dr = sr + 2")
    n = KernelFormSetup.IL(cm, n, "    Dim cnt As Long: cnt = 0")
    n = KernelFormSetup.IL(cm, n, "    Do While Len(Trim(CStr(wsC.Cells(dr, 1).Value))) > 0")
    n = KernelFormSetup.IL(cm, n, "        If Left(CStr(wsC.Cells(dr, 1).Value), 3) = ""==="" Then Exit Do")
    n = KernelFormSetup.IL(cm, n, "        Dim aID As String: aID = CStr(wsC.Cells(dr, 1).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aCat As String: aCat = CStr(wsC.Cells(dr, 2).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aDesc As String: aDesc = CStr(wsC.Cells(dr, 5).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aConf As String: aConf = CStr(wsC.Cells(dr, 8).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aSens As String: aSens = CStr(wsC.Cells(dr, 9).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aOwner As String: aOwner = CStr(wsC.Cells(dr, 11).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim aRev As String: aRev = CStr(wsC.Cells(dr, 12).Value)")
    n = KernelFormSetup.IL(cm, n, "        Dim show As Boolean: show = True")
    n = KernelFormSetup.IL(cm, n, "        If Left(aCat, 9) = ""ARCHIVED-"" Then show = False")
    n = KernelFormSetup.IL(cm, n, "        If optHighSens.Value And aSens <> ""High"" Then show = False")
    n = KernelFormSetup.IL(cm, n, "        If optStale.Value Then")
    n = KernelFormSetup.IL(cm, n, "            If Len(aRev) > 0 Then")
    n = KernelFormSetup.IL(cm, n, "                If DateDiff(""d"", CDate(aRev), Date) <= 90 Then show = False")
    n = KernelFormSetup.IL(cm, n, "            End If")
    n = KernelFormSetup.IL(cm, n, "        End If")
    n = KernelFormSetup.IL(cm, n, "        If show Then")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.AddItem aID")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 1) = aCat")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 2) = aDesc")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 3) = aConf")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 4) = aSens")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 5) = aOwner")
    n = KernelFormSetup.IL(cm, n, "            lstAssumptions.List(cnt, 6) = aRev")
    n = KernelFormSetup.IL(cm, n, "            cnt = cnt + 1")
    n = KernelFormSetup.IL(cm, n, "        End If")
    n = KernelFormSetup.IL(cm, n, "        dr = dr + 1")
    n = KernelFormSetup.IL(cm, n, "    Loop")
    n = KernelFormSetup.IL(cm, n, "    lblCount.Caption = cnt & "" assumptions""")
    n = KernelFormSetup.IL(cm, n, "    On Error GoTo 0")
    n = KernelFormSetup.IL(cm, n, "End Sub")
    n = KernelFormSetup.IL(cm, n, "")
    n = KernelFormSetup.IL(cm, n, "Private Sub lstAssumptions_Click()")
    n = KernelFormSetup.IL(cm, n, "    If lstAssumptions.ListIndex < 0 Then Exit Sub")
    n = KernelFormSetup.IL(cm, n, "    Dim aID As String: aID = lstAssumptions.List(lstAssumptions.ListIndex, 0)")
    n = KernelFormSetup.IL(cm, n, "    On Error Resume Next")
    n = KernelFormSetup.IL(cm, n, "    Dim wsC As Worksheet")
